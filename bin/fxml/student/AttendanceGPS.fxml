<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.student.AttendanceGPSController"
            fitToWidth="true" styleClass="scroll-transparent"
            stylesheets="@../../css/main.css">

    <VBox spacing="20">
        <padding><Insets top="24" bottom="24" left="24" right="24"/></padding>

        <!-- Phien dang mo -->
        <VBox styleClass="dashboard-card" spacing="14">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
            <HBox alignment="CENTER_LEFT">
                <Label text="▶  Phiên điểm danh đang mở" styleClass="card-title" HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblCountdown" text="--:--" styleClass="countdown-label"/>
            </HBox>

            <VBox fx:id="boxNoSession" alignment="CENTER" spacing="8">
                <padding><Insets top="20" bottom="20"/></padding>
                <Label text="😴" style="-fx-font-size:40px;"/>
                <Label text="Hiện chưa có phiên điểm danh nào được mở"
                       styleClass="empty-label"/>
                <Label text="Vui lòng chờ giảng viên mở phiên"
                       styleClass="form-subtitle"/>
                <Button text="🔄  Kiểm tra lại" styleClass="btn-primary"
                        prefHeight="40" prefWidth="160" onAction="#checkSession"/>
            </VBox>

            <VBox fx:id="boxSessionInfo" spacing="10" visible="false" managed="false">
                <Label fx:id="lblSubjectName"  text="" styleClass="schedule-subject"/>
                <Label fx:id="lblScheduleInfo" text="" styleClass="schedule-time"/>
                <HBox spacing="10">
                    <Label fx:id="lblMethodGPS"  text="📍 GPS"  styleClass="badge-present"/>
                    <Label fx:id="lblMethodWiFi" text="📶 WiFi" styleClass="badge-present"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- Xac minh vi tri GPS -->
        <VBox fx:id="boxGPS" styleClass="dashboard-card" spacing="14"
              visible="false" managed="false">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
            <Label text="📍  Xác minh vị trí GPS" styleClass="card-title"/>

            <VBox fx:id="boxGPSWaiting" alignment="CENTER" spacing="12">
                <padding><Insets top="16" bottom="16"/></padding>
                <Label text="📡" style="-fx-font-size:40px;"/>
                <Label text="Đang lấy vị trí của bạn..." styleClass="form-subtitle"/>
                <ProgressIndicator fx:id="gpsProgress" prefWidth="40" prefHeight="40"/>
                <Button text="📍  Lấy vị trí GPS" styleClass="btn-primary"
                        prefHeight="44" prefWidth="200" onAction="#getGPSLocation"/>
            </VBox>

            <VBox fx:id="boxGPSResult" spacing="10" visible="false" managed="false">
                <HBox spacing="12" styleClass="schedule-item" alignment="CENTER_LEFT">
                    <Label text="📍" style="-fx-font-size:20px;"/>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Vị trí của bạn" styleClass="field-label"/>
                        <Label fx:id="lblMyLocation" text="" styleClass="schedule-time"/>
                    </VBox>
                    <Label fx:id="lblGPSStatus" text="" styleClass="badge-present"/>
                </HBox>
                <HBox spacing="12" styleClass="schedule-item" alignment="CENTER_LEFT">
                    <Label text="🏫" style="-fx-font-size:20px;"/>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Vị trí lớp học" styleClass="field-label"/>
                        <Label fx:id="lblClassLocation" text="" styleClass="schedule-time"/>
                    </VBox>
                    <Label fx:id="lblDistance" text="" styleClass="badge-late"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- Xac minh WiFi -->
        <VBox fx:id="boxWiFi" styleClass="dashboard-card" spacing="14"
              visible="false" managed="false">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
            <Label text="📶  Xác minh WiFi" styleClass="card-title"/>

            <VBox fx:id="boxWiFiWaiting" alignment="CENTER" spacing="12">
                <padding><Insets top="16" bottom="16"/></padding>
                <Label text="📶" style="-fx-font-size:40px;"/>
                <Button text="📶  Quét WiFi" styleClass="btn-primary"
                        prefHeight="44" prefWidth="200" onAction="#scanWiFi"/>
            </VBox>

            <VBox fx:id="boxWiFiResult" spacing="10" visible="false" managed="false">
                <HBox spacing="12" styleClass="schedule-item" alignment="CENTER_LEFT">
                    <Label text="📶" style="-fx-font-size:20px;"/>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="WiFi hiện tại" styleClass="field-label"/>
                        <Label fx:id="lblCurrentWiFi" text="" styleClass="schedule-time"/>
                    </VBox>
                    <Label fx:id="lblWiFiStatus" text="" styleClass="badge-present"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- Nut diem danh -->
        <VBox spacing="8">
            <Label fx:id="lblError" text="" styleClass="error-label"
                   wrapText="true" maxWidth="Infinity"/>
            <Button fx:id="btnCheckin" text="✅  Điểm danh ngay"
                    styleClass="btn-primary" maxWidth="Infinity"
                    prefHeight="52" onAction="#handleCheckin"
                    disable="true"/>
        </VBox>

        <!-- Ket qua diem danh -->
        <VBox fx:id="boxSuccess" alignment="CENTER" spacing="16"
              visible="false" managed="false">
            <padding><Insets top="20" bottom="20"/></padding>
            <Label text="✅" style="-fx-font-size:56px;"/>
            <Label text="Điểm danh thành công!" styleClass="form-title"/>
            <Label fx:id="lblCheckinTime" text="" styleClass="form-subtitle"/>
        </VBox>

    </VBox>
</ScrollPane>
