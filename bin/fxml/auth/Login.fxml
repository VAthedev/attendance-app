<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.auth.LoginController"
            prefWidth="900" prefHeight="600"
            stylesheets="@../../css/main.css">

    <HBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- ===== PANEL TRAI (Banner) ===== -->
        <VBox styleClass="login-banner" alignment="CENTER" spacing="16"
              prefWidth="420">
            <padding><Insets top="60" bottom="60" left="40" right="40"/></padding>

            <Label text="🎓" styleClass="banner-icon"/>
            <Label text="Hệ thống TKB &amp; Điểm danh"
                   styleClass="banner-title" wrapText="true"
                   textAlignment="CENTER"/>
            <Label text="Quản lý thời khóa biểu và điểm danh sinh viên toàn trường một cách thông minh, chính xác và bảo mật."
                   styleClass="banner-subtitle" wrapText="true"
                   textAlignment="CENTER"/>

            <HBox alignment="CENTER" spacing="12">
                <VBox alignment="CENTER" styleClass="banner-stat">
                    <Label text="GPS" styleClass="stat-icon"/>
                    <Label text="Xác minh vị trí" styleClass="stat-label"/>
                </VBox>
                <VBox alignment="CENTER" styleClass="banner-stat">
                    <Label text="WiFi" styleClass="stat-icon"/>
                    <Label text="Kết nối nội bộ" styleClass="stat-label"/>
                </VBox>
                <VBox alignment="CENTER" styleClass="banner-stat">
                    <Label text="TLS" styleClass="stat-icon"/>
                    <Label text="Mã hóa bảo mật" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- ===== PANEL PHAI (Form) ===== -->
        <VBox styleClass="auth-form-panel" alignment="CENTER" spacing="0"
              HBox.hgrow="ALWAYS">
            <padding><Insets top="60" bottom="60" left="60" right="60"/></padding>

            <!-- Header -->
            <VBox spacing="6" alignment="CENTER_LEFT">
                <Label text="Đăng nhập" styleClass="form-title"/>
                <Label text="Nhập thông tin tài khoản để tiếp tục" styleClass="form-subtitle"/>
            </VBox>

            <Region prefHeight="32"/>

            <!-- Role selector -->
            <Label text="Đăng nhập với tư cách" styleClass="field-label"/>
            <Region prefHeight="8"/>
            <HBox spacing="12">
                <ToggleButton fx:id="btnRoleStudent" text="Sinh viên"
                              styleClass="role-toggle" selected="true"
                              toggleGroup="$roleGroup" prefWidth="180" prefHeight="40"/>
                <ToggleButton fx:id="btnRoleLecturer" text="Giảng viên"
                              styleClass="role-toggle"
                              toggleGroup="$roleGroup" prefWidth="180" prefHeight="40"/>
                <fx:define>
                    <ToggleGroup fx:id="roleGroup"/>
                </fx:define>
            </HBox>

            <Region prefHeight="20"/>

            <!-- Username -->
            <Label text="Tên đăng nhập" styleClass="field-label"/>
            <Region prefHeight="6"/>
            <TextField fx:id="txtUsername"
                       promptText="Nhập tên đăng nhập hoặc MSSV"
                       styleClass="auth-field" maxWidth="Infinity"/>

            <Region prefHeight="16"/>

            <!-- Password -->
            <Label text="Mật khẩu" styleClass="field-label"/>
            <Region prefHeight="6"/>
            <StackPane>
                <PasswordField fx:id="txtPassword"
                               promptText="Nhập mật khẩu"
                               styleClass="auth-field" maxWidth="Infinity"/>
                <Button fx:id="btnShowPass" text="👁"
                        styleClass="show-pass-btn"
                        onAction="#toggleShowPassword"
                        StackPane.alignment="CENTER_RIGHT"/>
            </StackPane>

            <Region prefHeight="8"/>

            <!-- Forgot password link -->
            <HBox alignment="CENTER_RIGHT">
                <Hyperlink fx:id="lnkForgot" text="Quên mật khẩu?"
                           styleClass="link-text" onAction="#goToForgotPassword"/>
            </HBox>

            <Region prefHeight="8"/>

            <!-- Error label -->
            <Label fx:id="lblError" text="" styleClass="error-label"
                   wrapText="true" maxWidth="Infinity"/>

            <Region prefHeight="16"/>

            <!-- Submit -->
            <Button fx:id="btnLogin" text="Đăng nhập"
                    styleClass="btn-primary" maxWidth="Infinity"
                    prefHeight="46" onAction="#handleLogin"/>

            <Region prefHeight="20"/>

            <!-- Divider -->
            <HBox alignment="CENTER" spacing="12">
                <Separator HBox.hgrow="ALWAYS"/>
                <Label text="hoặc" styleClass="divider-label"/>
                <Separator HBox.hgrow="ALWAYS"/>
            </HBox>

            <Region prefHeight="20"/>

            <!-- Register link -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Chưa có tài khoản?" styleClass="form-subtitle"/>
                <Hyperlink text="Đăng ký ngay" styleClass="link-text"
                           onAction="#goToRegister"/>
            </HBox>

        </VBox>
    </HBox>
</AnchorPane>
