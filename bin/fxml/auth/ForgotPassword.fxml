<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.auth.ForgotPasswordController"
            prefWidth="900" prefHeight="600"
            stylesheets="@../../css/main.css">

    <HBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- PANEL TRAI -->
        <VBox styleClass="login-banner" alignment="CENTER" spacing="16" prefWidth="380">
            <padding><Insets top="60" bottom="60" left="40" right="40"/></padding>

            <Label text="🔒" styleClass="banner-icon"/>
            <Label text="Khôi phục mật khẩu" styleClass="banner-title"
                   wrapText="true" textAlignment="CENTER"/>
            <Label text="Nhập email đã đăng ký. Chúng tôi sẽ gửi mã OTP để xác minh danh tính."
                   styleClass="banner-subtitle" wrapText="true" textAlignment="CENTER"/>

            <!-- Step indicator bang Label -->
            <HBox alignment="CENTER" spacing="0">
                <VBox alignment="CENTER" spacing="4">
                    <Label fx:id="stepCircle1" text="1" styleClass="step-circle-active" prefWidth="36" prefHeight="36"/>
                    <Label text="Email" styleClass="step-label-active"/>
                </VBox>
                <Region prefWidth="30" prefHeight="2" styleClass="step-line"/>
                <VBox alignment="CENTER" spacing="4">
                    <Label fx:id="stepCircle2" text="2" styleClass="step-circle" prefWidth="36" prefHeight="36"/>
                    <Label fx:id="stepLabel2" text="OTP" styleClass="step-label"/>
                </VBox>
                <Region prefWidth="30" prefHeight="2" styleClass="step-line"/>
                <VBox alignment="CENTER" spacing="4">
                    <Label fx:id="stepCircle3" text="3" styleClass="step-circle" prefWidth="36" prefHeight="36"/>
                    <Label fx:id="stepLabel3" text="Mật khẩu mới" styleClass="step-label"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- PANEL PHAI -->
        <StackPane HBox.hgrow="ALWAYS" styleClass="auth-form-panel">

            <!-- BUOC 1: Nhap email -->
            <VBox fx:id="paneStep1" alignment="CENTER" spacing="0" visible="true" managed="true">
                <padding><Insets left="60" right="60"/></padding>
                <Label text="Nhập email của bạn" styleClass="form-title"/>
                <Region prefHeight="8"/>
                <Label text="Chúng tôi sẽ gửi mã OTP xác minh về email này"
                       styleClass="form-subtitle" wrapText="true"/>
                <Region prefHeight="32"/>
                <Label text="Địa chỉ Email" styleClass="field-label" maxWidth="Infinity"/>
                <Region prefHeight="6"/>
                <TextField fx:id="txtEmail" promptText="example@student.edu.vn"
                           styleClass="auth-field" maxWidth="Infinity"/>
                <Region prefHeight="8"/>
                <Label fx:id="lblError1" text="" styleClass="error-label"
                       wrapText="true" maxWidth="Infinity"/>
                <Region prefHeight="16"/>
                <Button fx:id="btnSendOTP" text="Gửi mã OTP"
                        styleClass="btn-primary" maxWidth="Infinity"
                        prefHeight="46" onAction="#handleSendOTP"/>
                <Region prefHeight="20"/>
                <HBox alignment="CENTER" spacing="6">
                    <Label text="Nhớ mật khẩu rồi?" styleClass="form-subtitle"/>
                    <Hyperlink text="Đăng nhập" styleClass="link-text" onAction="#goToLogin"/>
                </HBox>
            </VBox>

            <!-- BUOC 2: Nhap OTP -->
            <VBox fx:id="paneStep2" alignment="CENTER" spacing="0" visible="false" managed="false">
                <padding><Insets left="60" right="60"/></padding>
                <Label text="Nhập mã OTP" styleClass="form-title"/>
                <Region prefHeight="8"/>
                <Label fx:id="lblOTPSentTo" text="Mã OTP đã được gửi đến email của bạn"
                       styleClass="form-subtitle" wrapText="true"/>
                <Region prefHeight="32"/>
                <HBox alignment="CENTER" spacing="12">
                    <TextField fx:id="otp1" styleClass="otp-field" prefWidth="52" prefHeight="60"/>
                    <TextField fx:id="otp2" styleClass="otp-field" prefWidth="52" prefHeight="60"/>
                    <TextField fx:id="otp3" styleClass="otp-field" prefWidth="52" prefHeight="60"/>
                    <TextField fx:id="otp4" styleClass="otp-field" prefWidth="52" prefHeight="60"/>
                    <TextField fx:id="otp5" styleClass="otp-field" prefWidth="52" prefHeight="60"/>
                    <TextField fx:id="otp6" styleClass="otp-field" prefWidth="52" prefHeight="60"/>
                </HBox>
                <Region prefHeight="12"/>
                <HBox alignment="CENTER" spacing="6">
                    <Label text="Mã hết hạn sau:" styleClass="form-subtitle"/>
                    <Label fx:id="lblCountdown" text="05:00" styleClass="countdown-label"/>
                </HBox>
                <Region prefHeight="8"/>
                <Label fx:id="lblError2" text="" styleClass="error-label"
                       wrapText="true" maxWidth="Infinity" textAlignment="CENTER"/>
                <Region prefHeight="16"/>
                <Button fx:id="btnVerifyOTP" text="Xác nhận OTP"
                        styleClass="btn-primary" maxWidth="Infinity"
                        prefHeight="46" onAction="#handleVerifyOTP"/>
                <Region prefHeight="12"/>
                <HBox alignment="CENTER" spacing="6">
                    <Label text="Không nhận được mã?" styleClass="form-subtitle"/>
                    <Hyperlink fx:id="lnkResend" text="Gửi lại" styleClass="link-text"
                               onAction="#handleResendOTP"/>
                </HBox>
            </VBox>

            <!-- BUOC 3: Dat mat khau moi -->
            <VBox fx:id="paneStep3" alignment="CENTER" spacing="0" visible="false" managed="false">
                <padding><Insets left="60" right="60"/></padding>
                <Label text="Đặt mật khẩu mới" styleClass="form-title"/>
                <Region prefHeight="8"/>
                <Label text="Tối thiểu 8 ký tự, gồm chữ và số"
                       styleClass="form-subtitle" wrapText="true"/>
                <Region prefHeight="32"/>
                <Label text="Mật khẩu mới" styleClass="field-label" maxWidth="Infinity"/>
                <Region prefHeight="6"/>
                <PasswordField fx:id="txtNewPassword" promptText="Tối thiểu 8 ký tự"
                               styleClass="auth-field" maxWidth="Infinity"/>
                <Region prefHeight="16"/>
                <Label text="Xác nhận mật khẩu mới" styleClass="field-label" maxWidth="Infinity"/>
                <Region prefHeight="6"/>
                <PasswordField fx:id="txtConfirmPassword" promptText="Nhập lại mật khẩu mới"
                               styleClass="auth-field" maxWidth="Infinity"/>
                <Region prefHeight="8"/>
                <Label fx:id="lblError3" text="" styleClass="error-label"
                       wrapText="true" maxWidth="Infinity"/>
                <Region prefHeight="16"/>
                <Button fx:id="btnResetPassword" text="Cập nhật mật khẩu"
                        styleClass="btn-primary" maxWidth="Infinity"
                        prefHeight="46" onAction="#handleResetPassword"/>
            </VBox>

            <!-- BUOC 4: Thanh cong -->
            <VBox fx:id="paneSuccess" alignment="CENTER" spacing="16" visible="false" managed="false">
                <padding><Insets left="60" right="60"/></padding>
                <Label text="✅" styleClass="success-icon"/>
                <Label text="Đặt lại mật khẩu thành công!" styleClass="form-title"
                       textAlignment="CENTER" wrapText="true"/>
                <Label text="Mật khẩu đã được cập nhật. Vui lòng đăng nhập lại."
                       styleClass="form-subtitle" wrapText="true" textAlignment="CENTER"/>
                <Region prefHeight="16"/>
                <Button text="Về trang đăng nhập" styleClass="btn-primary"
                        maxWidth="Infinity" prefHeight="46" onAction="#goToLogin"/>
            </VBox>

        </StackPane>
    </HBox>
</AnchorPane>
