<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="dashboard-card" spacing="12" prefWidth="750"
      xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.widgets.StudentNotificationsWidgetController">
    <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
    <HBox alignment="CENTER_LEFT">
        <Label text="🔔  Thông báo mới nhất" styleClass="card-title" HBox.hgrow="ALWAYS"/>
        <Hyperlink text="Xem tất cả" styleClass="link-text" onAction="#handleShowAll"/>
    </HBox>
    <VBox fx:id="boxNotifications" spacing="8"/>
    <Label fx:id="lblNoNotif" text="Không có thông báo mới"
           styleClass="empty-label" visible="false" managed="false"/>
</VBox>
