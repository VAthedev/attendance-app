<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="dashboard-card" prefWidth="340" spacing="12" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.widgets.ActiveSessionsWidgetController">
    <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
    <HBox alignment="CENTER_LEFT">
        <Label text="▶  Phiên điểm danh đang mở" styleClass="card-title" HBox.hgrow="ALWAYS"/>
    </HBox>
    <VBox fx:id="boxActiveSessions" spacing="8"/>
    <Label fx:id="lblNoSession" text="Không có phiên nào đang mở"
           styleClass="empty-label"/>
</VBox>
