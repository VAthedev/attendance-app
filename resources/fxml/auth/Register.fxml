<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.auth.RegisterController"
            prefWidth="900" prefHeight="600"
            stylesheets="@../../css/main.css">

    <HBox AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- ===== PANEL TRAI (Banner) ===== -->
        <VBox styleClass="login-banner" alignment="CENTER" spacing="16"
              prefWidth="420">
            <padding><Insets top="60" bottom="60" left="40" right="40"/></padding>

            <Label text="📝" styleClass="banner-icon"/>
            <Label text="Tạo tài khoản mới"
                   styleClass="banner-title" wrapText="true"
                   textAlignment="CENTER"/>
            <Label text="Đăng ký để sử dụng đầy đủ tính năng quản lý thời khóa biểu và điểm danh."
                   styleClass="banner-subtitle" wrapText="true"
                   textAlignment="CENTER"/>

            <VBox styleClass="register-feature-list" spacing="10" alignment="CENTER_LEFT">
                <HBox styleClass="register-feature-item" spacing="10" alignment="CENTER_LEFT">
                    <Label text="✓" styleClass="register-feature-icon"/>
                    <Label text="Xem TKB theo ngày / tuần" styleClass="register-feature-text"/>
                </HBox>
                <HBox styleClass="register-feature-item" spacing="10" alignment="CENTER_LEFT">
                    <Label text="✓" styleClass="register-feature-icon"/>
                    <Label text="Điểm danh GPS và WiFi" styleClass="register-feature-text"/>
                </HBox>
                <HBox styleClass="register-feature-item" spacing="10" alignment="CENTER_LEFT">
                    <Label text="✓" styleClass="register-feature-icon"/>
                    <Label text="Thống kê chuyên cần" styleClass="register-feature-text"/>
                </HBox>
                <HBox styleClass="register-feature-item" spacing="10" alignment="CENTER_LEFT">
                    <Label text="✓" styleClass="register-feature-icon"/>
                    <Label text="Nhận thông báo tự động" styleClass="register-feature-text"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- ===== PANEL PHAI (Form) ===== -->
        <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS"
                    styleClass="scroll-transparent">
            <VBox styleClass="auth-form-panel" alignment="TOP_CENTER" spacing="0">
                <padding><Insets top="52" bottom="52" left="60" right="60"/></padding>

                <VBox maxWidth="420" spacing="0" fillWidth="true">

                    <!-- Header -->
                    <VBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="Đăng ký" styleClass="form-title"/>
                        <Label text="Tạo tài khoản để bắt đầu sử dụng hệ thống" styleClass="form-subtitle"/>
                    </VBox>

                    <Region prefHeight="24"/>

                    <!-- Role selector -->
                    <Label text="Đăng ký với tư cách" styleClass="field-label"/>
                    <Region prefHeight="8"/>
                    <HBox spacing="12">
                        <ToggleButton fx:id="btnRoleStudent" text="Sinh viên"
                                      styleClass="role-toggle" selected="true"
                                      toggleGroup="$roleGroup" prefWidth="180" prefHeight="40"/>
                        <ToggleButton fx:id="btnRoleLecturer" text="Giảng viên"
                                      styleClass="role-toggle"
                                      toggleGroup="$roleGroup" prefWidth="180" prefHeight="40"/>
                        <fx:define>
                            <ToggleGroup fx:id="roleGroup"/>
                        </fx:define>
                    </HBox>

                    <Region prefHeight="18"/>

                    <!-- Họ tên -->
                    <Label text="Họ và tên" styleClass="field-label"/>
                    <Region prefHeight="6"/>
                    <TextField fx:id="txtFullName"
                               promptText="Nguyễn Văn A"
                               styleClass="auth-field" maxWidth="Infinity"/>

                    <Region prefHeight="14"/>

                    <!-- MSSV / MSGV -->
                    <Label fx:id="lblStudentId" text="MSSV" styleClass="field-label"/>
                    <Region prefHeight="6"/>
                    <TextField fx:id="txtStudentId"
                               promptText="VD: 2151234567"
                               styleClass="auth-field" maxWidth="Infinity"/>

                    <Region prefHeight="14"/>

                    <!-- Username -->
                    <Label text="Tên đăng nhập" styleClass="field-label"/>
                    <Region prefHeight="6"/>
                    <TextField fx:id="txtUsername"
                               promptText="Nhập tên đăng nhập"
                               styleClass="auth-field" maxWidth="Infinity"/>

                    <Region prefHeight="14"/>

                    <!-- Email -->
                    <Label text="Email" styleClass="field-label"/>
                    <Region prefHeight="6"/>
                    <TextField fx:id="txtEmail"
                               promptText="example@email.com"
                               styleClass="auth-field" maxWidth="Infinity"/>

                    <Region prefHeight="14"/>

                    <!-- Password -->
                    <Label text="Mật khẩu" styleClass="field-label"/>
                    <Region prefHeight="6"/>
                    <PasswordField fx:id="txtPassword"
                                   promptText="Tối thiểu 8 ký tự"
                                   styleClass="auth-field" maxWidth="Infinity"/>

                    <Region prefHeight="14"/>

                    <!-- Confirm Password -->
                    <Label text="Xác nhận mật khẩu" styleClass="field-label"/>
                    <Region prefHeight="6"/>
                    <PasswordField fx:id="txtConfirmPassword"
                                   promptText="Nhập lại mật khẩu"
                                   styleClass="auth-field" maxWidth="Infinity"/>

                    <Region prefHeight="8"/>

                    <!-- Password strength bar -->
                    <HBox spacing="6">
                        <Region fx:id="pwBar1" styleClass="pw-bar" prefHeight="4" HBox.hgrow="ALWAYS"/>
                        <Region fx:id="pwBar2" styleClass="pw-bar" prefHeight="4" HBox.hgrow="ALWAYS"/>
                        <Region fx:id="pwBar3" styleClass="pw-bar" prefHeight="4" HBox.hgrow="ALWAYS"/>
                        <Region fx:id="pwBar4" styleClass="pw-bar" prefHeight="4" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <Label fx:id="lblPwStrength" text="" styleClass="pw-strength-label"/>

                    <Region prefHeight="14"/>

                    <!-- Error -->
                    <Label fx:id="lblError" text="" styleClass="error-label"
                           wrapText="true" maxWidth="Infinity"/>

                    <Region prefHeight="14"/>

                    <!-- Submit -->
                    <Button fx:id="btnRegister" text="Tạo tài khoản"
                            styleClass="btn-primary" maxWidth="Infinity"
                            prefHeight="46" onAction="#handleRegister"/>

                    <Region prefHeight="18"/>

                    <!-- Divider -->
                    <HBox alignment="CENTER" spacing="12">
                        <Separator HBox.hgrow="ALWAYS"/>
                        <Label text="hoặc" styleClass="divider-label"/>
                        <Separator HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <Region prefHeight="16"/>

                    <!-- Login link -->
                    <HBox alignment="CENTER" spacing="6">
                        <Label text="Đã có tài khoản?" styleClass="form-subtitle"/>
                        <Hyperlink text="Đăng nhập" styleClass="link-text"
                                   onAction="#goToLogin"/>
                    </HBox>

                </VBox>
            </VBox>
        </ScrollPane>
    </HBox>
</AnchorPane>
