<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.lecturer.LecturerAttendanceListController"
      spacing="20" style="-fx-background-color: transparent;">
    
    <padding><Insets top="20" right="30" bottom="20" left="30"/></padding>

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="Danh sách các phiên điểm danh" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1a237e;"/>
        <Region HBox.hgrow="ALWAYS"/>
        
        <!-- Filters -->
        <ComboBox fx:id="cmbStatusFilter" prefWidth="150" promptText="Trạng thái" styleClass="btn-outline"/>
        <TextField fx:id="txtSearch" promptText="Tìm môn học, lớp..." prefWidth="250" styleClass="text-field"/>
        <Button text="Tìm kiếm" onAction="#handleSearch" styleClass="btn-primary"/>
    </HBox>

    <Separator/>

    <!-- Main List content -->
    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
        <VBox fx:id="listContainer" spacing="15" style="-fx-background-color: transparent;">
            <!-- Cards will be injected here dynamically -->
        </VBox>
    </ScrollPane>

</VBox>
