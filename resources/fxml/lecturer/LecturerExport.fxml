<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" style="-fx-background-color: #f8fafc; -fx-padding: 20;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.lecturer.LecturerExportController">
   <children>
      <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 2);">
         <children>
            <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1e293b;" text="Chọn lớp học:" />
            <ComboBox fx:id="cbClasses" prefWidth="300.0" promptText="-- Chọn lớp --" style="-fx-background-color: #f1f5f9; -fx-border-color: #e2e8f0; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 2;" />
            <HBox alignment="CENTER_RIGHT" spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleExportExcel" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 15; -fx-cursor: hand;" text="📊 Xuất Excel" />
                  <Button mnemonicParsing="false" onAction="#handleExportCSV" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 15; -fx-cursor: hand;" text="📥 Xuất CSV" />
               </children>
            </HBox>
         </children>
      </HBox>
      <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 2);" VBox.vgrow="ALWAYS">
         <children>
            <TableView fx:id="tableStudents" prefHeight="400.0" prefWidth="600.0" style="-fx-border-color: #e2e8f0; -fx-border-radius: 5;" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colStudentId" prefWidth="120.0" text="MSSV" />
                <TableColumn fx:id="colStudentName" prefWidth="250.0" text="Họ và Tên" />
                  <TableColumn fx:id="colPresent" prefWidth="120.0" text="Số buổi có mặt" />
                  <TableColumn fx:id="colAbsent" prefWidth="120.0" text="Số buổi vắng" />
                  <TableColumn fx:id="colAttendanceRate" prefWidth="150.0" text="Tỉ lệ chuyên cần (%)" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </children>
</VBox>
