<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.lecturer.OpenSessionController"
            fitToWidth="true" styleClass="scroll-transparent"
            stylesheets="@../../css/main.css">

    <VBox spacing="20">
        <padding><Insets top="24" bottom="24" left="24" right="24"/></padding>

        <!-- Chon mon hoc -->
        <VBox styleClass="dashboard-card" spacing="14">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
            <Label text="📚  Chọn môn học" styleClass="card-title"/>

            <HBox spacing="16">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Môn học" styleClass="field-label"/>
                    <ComboBox fx:id="cmbSubject" promptText="Chọn môn học..."
                              maxWidth="Infinity" styleClass="auth-field"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Buổi học" styleClass="field-label"/>
                    <ComboBox fx:id="cmbSchedule" promptText="Chọn buổi học..."
                              maxWidth="Infinity" styleClass="auth-field"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Cau hinh phien -->
        <VBox styleClass="dashboard-card" spacing="14">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
            <Label text="⚙️  Cấu hình phiên điểm danh" styleClass="card-title"/>

            <HBox spacing="16">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Thời gian mở (phút)" styleClass="field-label"/>
                    <TextField fx:id="txtDuration" text="15"
                               styleClass="auth-field" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Phương thức xác minh" styleClass="field-label"/>
                    <HBox spacing="12">
                        <CheckBox fx:id="chkGPS"  text="GPS"  selected="true"/>
                        <CheckBox fx:id="chkWiFi" text="WiFi" selected="true"/>
                    </HBox>
                </VBox>
            </HBox>

            <!-- GPS config -->
            <VBox fx:id="boxGPSConfig" spacing="10">
                <Label text="📍  Cấu hình GPS" styleClass="field-label"/>
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Vĩ độ (Latitude)" styleClass="field-label"/>
                        <TextField fx:id="txtLat" promptText="VD: 10.7769" styleClass="auth-field" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Kinh độ (Longitude)" styleClass="field-label"/>
                        <TextField fx:id="txtLng" promptText="VD: 106.7009" styleClass="auth-field" maxWidth="Infinity"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Bán kính (m)" styleClass="field-label"/>
                        <TextField fx:id="txtRadius" text="100" styleClass="auth-field" prefWidth="100"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- WiFi config -->
            <VBox fx:id="boxWiFiConfig" spacing="6">
                <Label text="📶  BSSID WiFi trường" styleClass="field-label"/>
                <TextField fx:id="txtBSSID" promptText="VD: AA:BB:CC:DD:EE:FF"
                           styleClass="auth-field" maxWidth="Infinity"/>
            </VBox>
        </VBox>

        <!-- Hien thi phien dang mo -->
        <VBox fx:id="boxActiveSession" styleClass="dashboard-card" spacing="14"
              visible="false" managed="false">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
            <Label text="▶  Phiên đang mở" styleClass="card-title"/>

            <HBox spacing="20" alignment="CENTER_LEFT">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblSessionSubject" text="" styleClass="schedule-subject"/>
                    <Label fx:id="lblSessionInfo"    text="" styleClass="schedule-time"/>
                </VBox>
                <VBox alignment="CENTER" spacing="4">
                    <Label text="Đếm ngược" styleClass="field-label"/>
                    <Label fx:id="lblCountdown" text="15:00" styleClass="countdown-label"
                           style="-fx-font-size:28px;"/>
                </VBox>
            </HBox>

            <!-- Progress diem danh -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Đã điểm danh:" styleClass="schedule-time"/>
                <Label fx:id="lblCheckedIn" text="0 / 0 sinh viên"
                       style="-fx-font-weight:bold;-fx-text-fill:#16a34a;"/>
            </HBox>
            <ProgressBar fx:id="progressAttendance" progress="0"
                         maxWidth="Infinity" prefHeight="10"/>

            <HBox spacing="12">
                <Button fx:id="btnCloseSession" text="⏹  Đóng phiên sớm"
                        styleClass="btn-danger" prefHeight="40" onAction="#handleCloseSession"/>
                <Button text="🔄  Làm mới" styleClass="btn-secondary"
                        prefHeight="40" onAction="#refreshSession"/>
            </HBox>
        </VBox>

        <!-- Nut mo phien -->
        <VBox fx:id="boxOpenBtn">
            <Label fx:id="lblError" text="" styleClass="error-label"
                   wrapText="true" maxWidth="Infinity"/>
            <Region prefHeight="8"/>
            <Button fx:id="btnOpenSession" text="▶  Mở phiên điểm danh"
                    styleClass="btn-primary" maxWidth="Infinity"
                    prefHeight="50" onAction="#handleOpenSession"/>
        </VBox>

    </VBox>
</ScrollPane>
