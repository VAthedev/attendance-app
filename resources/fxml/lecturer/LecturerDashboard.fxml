<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.lecturer.LecturerDashboardController"
            prefWidth="1100" prefHeight="680"
            stylesheets="@../../css/main.css">
    <BorderPane>

    <!-- ===== SIDEBAR ===== -->
    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="4">
            <padding><Insets top="0" bottom="20" left="0" right="0"/></padding>

            <VBox styleClass="sidebar-logo" alignment="CENTER">
                <padding><Insets top="24" bottom="24"/></padding>
                <Label text="🎓" style="-fx-font-size:32px;"/>
                <Label text="AttendanceApp" styleClass="sidebar-app-name"/>
            </VBox>

            <VBox styleClass="sidebar-user" alignment="CENTER" spacing="4">
                <padding><Insets top="12" bottom="16" left="16" right="16"/></padding>
                <Label text="👤" style="-fx-font-size:36px;"/>
                <Label fx:id="lblUserName"  text="Giang Vien"     styleClass="sidebar-username"/>
                <Label fx:id="lblUserCode"  text="Ma GV: GV001"   styleClass="sidebar-userid"/>
                <Label text="Giảng viên" styleClass="role-badge-lecturer"/>
            </VBox>

            <Separator/>
            <Region prefHeight="8"/>

            <Button fx:id="btnDashboard" text="🏠  Tổng quan"
                    styleClass="sidebar-btn,sidebar-btn-active"
                    maxWidth="Infinity" onAction="#showDashboard"/>
            <Button fx:id="btnSchedule"  text="📅  Quản lý TKB"
                    styleClass="sidebar-btn" maxWidth="Infinity" onAction="#showSchedule"/>

            <Separator/>
            <Region prefHeight="4"/>

            <Button fx:id="btnOpenSession" text="▶  Mở phiên điểm danh"
                    styleClass="sidebar-btn" maxWidth="Infinity" onAction="#showOpenSession"/>
            <Button fx:id="btnAttendanceList" text="📋  Danh sách điểm danh"
                    styleClass="sidebar-btn" maxWidth="Infinity" onAction="#showAttendanceList"/>
            <Button fx:id="btnStatistics"  text="📊  Thống kê chuyên cần"
                    styleClass="sidebar-btn" maxWidth="Infinity" onAction="#showStatistics"/>
            <Button fx:id="btnExport"      text="📥  Xuất danh sách"
                    styleClass="sidebar-btn" maxWidth="Infinity" onAction="#showExport"/>

            <Separator/>
            <Region prefHeight="4"/>

            <Button fx:id="btnChat"         text="💬  Chat lớp học"
                    styleClass="sidebar-btn" maxWidth="Infinity" onAction="#showChat"/>
            <Button fx:id="btnNotification" text="🔔  Thông báo"
                    styleClass="sidebar-btn" maxWidth="Infinity" onAction="#showNotification"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Separator/>
            <Button text="🚪  Đăng xuất" styleClass="sidebar-btn,sidebar-btn-logout"
                    maxWidth="Infinity" onAction="#handleLogout"/>
        </VBox>
    </left>

    <!-- ===== NOI DUNG CHINH ===== -->
    <center>
        <VBox spacing="0">

            <!-- Topbar -->
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
                <padding><Insets top="16" bottom="16" left="24" right="24"/></padding>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblPageTitle" text="Tổng quan" styleClass="page-title"/>
                    <Label fx:id="lblPageDate"  text=""           styleClass="page-date"/>
                </VBox>
                <Button fx:id="btnSyncTKB" text="🔄  Đồng bộ TKB"
                        styleClass="btn-secondary" onAction="#handleSyncTKB"/>
                <Button fx:id="btnQuickOpen" text="▶  Mở điểm danh nhanh"
                        styleClass="btn-primary" onAction="#showOpenSession"/>
            </HBox>

            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS">

                <!-- ===== TRANG TONG QUAN ===== -->
                <ScrollPane fx:id="paneDashboard" fitToWidth="true"
                            styleClass="scroll-transparent" visible="true" managed="true">
                    <FlowPane fx:id="widgetContainer" hgap="16" vgap="16">
                        <padding><Insets top="24" bottom="24" left="24" right="24"/></padding>
                        <!-- Dynamic widgets will be loaded here -->
                    </FlowPane>
                </ScrollPane>

                <!-- Coming soon pane -->
                <Label fx:id="paneComingSoon" text="Tính năng đang phát triển..."
                       styleClass="coming-soon-label" visible="false" managed="false"/>

            </StackPane>
        </VBox>
    </center>

    </BorderPane>

    <!-- FLOATING AI CHAT WIDGET -->
    <StackPane fx:id="aiChatWidget" maxHeight="500" maxWidth="400"
          StackPane.alignment="BOTTOM_RIGHT" visible="false" managed="false"
          style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 20, 0, 0, 10); -fx-background-radius: 10; -fx-border-radius: 10; -fx-background-color: transparent;">
        <StackPane.margin>
            <Insets bottom="90" right="30"/>
        </StackPane.margin>
        <fx:include source="../Chatbot.fxml"/>
    </StackPane>

    <!-- FLOATING AI BUTTON -->
    <Button text="🤖 AI Trợ lý" onAction="#toggleAIChat"
            style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 50; -fx-font-weight: bold; -fx-padding: 15 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 5); -fx-font-size: 14px; -fx-cursor: hand;"
            StackPane.alignment="BOTTOM_RIGHT">
        <StackPane.margin>
            <Insets bottom="30" right="30"/>
        </StackPane.margin>
    </Button>
</StackPane>
