<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.student.AttendanceStatisticController"
            fitToWidth="true" styleClass="scroll-transparent"
            stylesheets="@../../css/main.css">

    <VBox spacing="20">
        <padding><Insets top="24" bottom="24" left="24" right="24"/></padding>

        <!-- Header -->
        <VBox styleClass="dashboard-card" spacing="10">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="📊" style="-fx-font-size: 32px;"/>
                <VBox>
                    <Label text="THỐNG KÊ CHUYÊN CẦN" styleClass="card-title"/>
                    <Label text="Tổng hợp tỷ lệ điểm danh theo từng môn học" styleClass="form-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="cbSemester" prefWidth="150" promptText="Chọn học kỳ" onAction="#onSemesterChanged"/>
            </HBox>
        </VBox>

        <!-- Tổng quan chung -->
        <VBox styleClass="dashboard-card" spacing="15">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
            <Label text="🎯 TỔNG QUAN HỌC KỲ" styleClass="card-title"/>
            
            <GridPane hgap="20" vgap="15" alignment="CENTER">
                <!-- Tổng số môn -->
                <Label text="Số môn học:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="stat-label"/>
                <Label fx:id="lblTotalSubjects" text="0" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                
                <!-- Chuyên cần trung bình -->
                <Label text="Chuyên cần TB:" GridPane.rowIndex="0" GridPane.columnIndex="2" styleClass="stat-label"/>
                <Label fx:id="lblAvgAttendance" text="0%" GridPane.rowIndex="0" GridPane.columnIndex="3" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                
                <!-- Tổng số buổi -->
                <Label text="Tổng số buổi:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="stat-label"/>
                <Label fx:id="lblTotalClasses" text="0" GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                
                <!-- Đã điểm danh -->
                <Label text="Đã điểm danh:" GridPane.rowIndex="1" GridPane.columnIndex="2" styleClass="stat-label"/>
                <Label fx:id="lblTotalPresent" text="0" GridPane.rowIndex="1" GridPane.columnIndex="3" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                
                <!-- Vắng -->
                <Label text="Vắng mặt:" GridPane.rowIndex="1" GridPane.columnIndex="4" styleClass="stat-label"/>
                <Label fx:id="lblTotalAbsent" text="0" GridPane.rowIndex="1" GridPane.columnIndex="5" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
            </GridPane>
            
            <!-- Progress bar tổng thể -->
            <VBox spacing="5">
                <HBox>
                    <Label text="Tỷ lệ chuyên cần tổng thể:" styleClass="field-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblOverallPercent" text="0%" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                </HBox>
                <ProgressBar fx:id="overallProgress" prefHeight="25" styleClass="stat-progress" progress="0.0"/>
            </VBox>
        </VBox>

        <!-- Biểu đồ chuyên cần -->
        <VBox styleClass="dashboard-card" spacing="15">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
            <Label text="📈 BIỂU ĐỒ CHUYÊN CẦN THEO MÔN" styleClass="card-title"/>
            
            <TabPane>
                <Tab text="Biểu đồ cột">
                    <VBox spacing="10">
                        <padding><Insets top="10"/></padding>
                        <BarChart fx:id="barChart" title="Tỷ lệ chuyên cần theo môn" style="-fx-font-size: 12px;">
                            <xAxis>
                                <CategoryAxis fx:id="xAxis" label="Môn học"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis fx:id="yAxis" label="Tỷ lệ (%)" tickUnit="10" upperBound="100"/>
                            </yAxis>
                        </BarChart>
                    </VBox>
                </Tab>
                <Tab text="Biểu đồ tròn">
                    <VBox spacing="10">
                        <padding><Insets top="10"/></padding>
                        <PieChart fx:id="pieChart" title="Phân bổ trạng thái điểm danh" legendVisible="true"/>
                    </VBox>
                </Tab>
                <Tab text="Biểu đồ đường">
                    <VBox spacing="10">
                        <padding><Insets top="10"/></padding>
                        <LineChart fx:id="lineChart" title="Xu hướng chuyên cần theo tuần">
                            <xAxis>
                                <CategoryAxis fx:id="weekAxis" label="Tuần"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis fx:id="percentAxis" label="Tỷ lệ (%)" tickUnit="10" upperBound="100"/>
                            </yAxis>
                        </LineChart>
                    </VBox>
                </Tab>
            </TabPane>
        </VBox>

        <!-- Bảng chi tiết từng môn -->
        <VBox styleClass="dashboard-card" spacing="15">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
            <Label text="📋 CHI TIẾT TỪNG MÔN HỌC" styleClass="card-title"/>
            
            <TableView fx:id="tvSubjectStats" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colSubjectName" text="MÔN HỌC" prefWidth="200"/>
                    <TableColumn fx:id="colTotalClasses" text="TỔNG BUỔI" prefWidth="100" alignment="CENTER"/>
                    <TableColumn fx:id="colPresent" text="ĐÃ ĐIỂM DANH" prefWidth="120" alignment="CENTER"/>
                    <TableColumn fx:id="colAbsent" text="VẮNG" prefWidth="80" alignment="CENTER"/>
                    <TableColumn fx:id="colLate" text="MUỘN" prefWidth="80" alignment="CENTER"/>
                    <TableColumn fx:id="colPercent" text="CHUYÊN CẦN" prefWidth="120" alignment="CENTER"/>
                    <TableColumn fx:id="colStatus" text="ĐÁNH GIÁ" prefWidth="120" alignment="CENTER"/>
                    <TableColumn fx:id="colDetail" text="CHI TIẾT" prefWidth="80" alignment="CENTER"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>

        <!-- Khuyến nghị -->
        <VBox fx:id="boxRecommendation" styleClass="dashboard-card" spacing="10" visible="false" managed="false">
            <padding><Insets top="15" bottom="15" left="20" right="20"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="💡" style="-fx-font-size: 24px;"/>
                <VBox>
                    <Label text="KHUYẾN NGHỊ" styleClass="card-title-small"/>
                    <Label fx:id="lblRecommendation" text="" wrapText="true" styleClass="form-subtitle"/>
                </VBox>
            </HBox>
        </VBox>

    </VBox>
</ScrollPane>