<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.student.AttendanceHistoryController"
            fitToWidth="true" styleClass="scroll-transparent"
            stylesheets="@../../css/main.css">

    <VBox spacing="20">
        <padding><Insets top="24" bottom="24" left="24" right="24"/></padding>

        <!-- Header -->
        <VBox styleClass="dashboard-card" spacing="10">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="📋" style="-fx-font-size: 32px;"/>
                <VBox>
                    <Label text="LỊCH SỬ ĐIỂM DANH" styleClass="card-title"/>
                    <Label text="Xem lại các lần điểm danh của bạn" styleClass="form-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                
                <!-- Bộ lọc -->
                <HBox spacing="10" alignment="CENTER">
                    <Label text="Lọc:" styleClass="field-label"/>
                    <ComboBox fx:id="cbFilterMonth" prefWidth="120" promptText="Chọn tháng">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Tháng 1"/>
                                <String fx:value="Tháng 2"/>
                                <String fx:value="Tháng 3"/>
                                <String fx:value="Tháng 4"/>
                                <String fx:value="Tháng 5"/>
                                <String fx:value="Tháng 6"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                    <ComboBox fx:id="cbFilterSubject" prefWidth="150" promptText="Chọn môn học"/>
                    <Button text="🔍 Lọc" styleClass="btn-secondary" onAction="#applyFilter"/>
                    <Button text="🔄 Làm mới" styleClass="btn-secondary" onAction="#refreshHistory"/>
                </HBox>
            </HBox>
        </VBox>

        <!-- Tóm tắt thống kê nhanh -->
        <VBox styleClass="dashboard-card" spacing="15">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
            <Label text="📊 TỔNG QUAN" styleClass="card-title"/>
            
            <HBox spacing="20" alignment="CENTER">
                <!-- Tổng số buổi -->
                <VBox alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS" styleClass="stat-box">
                    <Label text="📚" style="-fx-font-size: 28px;"/>
                    <Label fx:id="lblTotalSessions" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="Tổng số buổi" styleClass="stat-label"/>
                </VBox>
                
                <!-- Đã điểm danh -->
                <VBox alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS" styleClass="stat-box">
                    <Label text="✅" style="-fx-font-size: 28px;"/>
                    <Label fx:id="lblPresent" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                    <Label text="Đã điểm danh" styleClass="stat-label"/>
                </VBox>
                
                <!-- Vắng -->
                <VBox alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS" styleClass="stat-box">
                    <Label text="❌" style="-fx-font-size: 28px;"/>
                    <Label fx:id="lblAbsent" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                    <Label text="Vắng mặt" styleClass="stat-label"/>
                </VBox>
                
                <!-- Muộn -->
                <VBox alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS" styleClass="stat-box">
                    <Label text="⏰" style="-fx-font-size: 28px;"/>
                    <Label fx:id="lblLate" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
                    <Label text="Đi muộn" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Danh sách lịch sử điểm danh -->
        <VBox styleClass="dashboard-card" spacing="15">
            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
            <Label text="📝 CHI TIẾT BUỔI HỌC" styleClass="card-title"/>
            
            <!-- Loading indicator -->
            <VBox fx:id="boxLoading" alignment="CENTER" spacing="10" visible="false" managed="false">
                <ProgressIndicator prefWidth="50" prefHeight="50"/>
                <Label text="Đang tải dữ liệu..." styleClass="form-subtitle"/>
            </VBox>
            
            <!-- Bảng lịch sử -->
            <TableView fx:id="tvAttendanceHistory" styleClass="table-view" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colDate" text="NGÀY" prefWidth="120"/>
                    <TableColumn fx:id="colSubject" text="MÔN HỌC" prefWidth="200"/>
                    <TableColumn fx:id="colTime" text="THỜI GIAN" prefWidth="120"/>
                    <TableColumn fx:id="colMethod" text="PHƯƠNG THỨC" prefWidth="120"/>
                    <TableColumn fx:id="colStatus" text="TRẠNG THÁI" prefWidth="100"/>
                    <TableColumn fx:id="colLocation" text="VỊ TRÍ" prefWidth="150"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
            
            <!-- Pagination -->
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Label text="Hiển thị:" styleClass="field-label"/>
                <ComboBox fx:id="cbPageSize" value="10" prefWidth="70">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <Integer fx:value="10"/>
                            <Integer fx:value="20"/>
                            <Integer fx:value="50"/>
                            <Integer fx:value="100"/>
                        </FXCollections>
                    </items>
                </ComboBox>
                <Label text="dòng" styleClass="field-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Pagination fx:id="pagination" maxPageIndicatorCount="5" style="-fx-border-color: transparent;"/>
            </HBox>
            
            <!-- Empty state -->
            <VBox fx:id="boxEmpty" alignment="CENTER" spacing="10" visible="false" managed="false">
                <padding><Insets top="30" bottom="30"/></padding>
                <Label text="📭" style="-fx-font-size: 48px;"/>
                <Label text="Chưa có dữ liệu điểm danh" styleClass="empty-label"/>
                <Label text="Hãy tham gia điểm danh để xem lịch sử" styleClass="form-subtitle"/>
            </VBox>
        </VBox>
        
        <!-- Nút xuất báo cáo -->
        <HBox spacing="15" alignment="CENTER_RIGHT">
            <Button text="📥 Xuất Excel" styleClass="btn-primary" onAction="#exportToExcel"/>
            <Button text="🖨️ In báo cáo" styleClass="btn-secondary" onAction="#printReport"/>
        </HBox>

    </VBox>
</ScrollPane>