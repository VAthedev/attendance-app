<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="500.0" prefWidth="400.0" style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ChatbotController">
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="50.0" style="-fx-background-color: #2196F3;" BorderPane.alignment="CENTER">
         <children>
            <Label text="AI Trợ Lý Học Vụ" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets left="15.0" />
         </padding>
      </HBox>
   </top>
   <center>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <ListView fx:id="chatListView" focusTraversable="false" style="-fx-background-color: transparent; -fx-control-inner-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER" prefHeight="30.0">
               <children>
                  <ProgressIndicator fx:id="loadingIndicator" prefHeight="20.0" prefWidth="20.0" visible="false" />
                  <Label fx:id="statusLabel" text="Đang trả lời..." textFill="#666666" visible="false">
                     <HBox.margin>
                        <Insets left="5.0" />
                     </HBox.margin>
                  </Label>
               </children>
            </HBox>
         </children>
      </VBox>
   </center>
   <bottom>
      <HBox alignment="CENTER" prefHeight="60.0" spacing="10.0" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;" BorderPane.alignment="CENTER">
         <children>
            <TextField fx:id="inputField" onAction="#handleSend" prefHeight="35.0" promptText="Hỏi về lịch học, điểm danh..." style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-border-color: #ccc; -fx-background-color: white;" HBox.hgrow="ALWAYS">
               <padding>
                  <Insets left="15.0" right="15.0" />
               </padding>
            </TextField>
            <Button fx:id="sendButton" mnemonicParsing="false" onAction="#handleSend" prefHeight="35.0" prefWidth="60.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-background-radius: 20;" text="Gửi">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Button>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>
