{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Launch Server",
      "request": "launch",
      "mainClass": "server.Server",
      "projectName": "attendance-app",
      "classPaths": [
        "bin",
        "lib/*"
      ]
    },
    {
      "type": "java",
      "name": "Launch Client (JavaFX)",
      "request": "launch",
      "mainClass": "client.Main",
      "projectName": "attendance-app",
      "classPaths": [
        "bin",
        "lib/*"
      ],
      "vmArgs": "--module-path ${workspaceFolder}\\lib\\javafx-sdk-21\\lib --add-modules javafx.controls,javafx.fxml"
    }
  ]
}